{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-conf-schema/main/schema.json",
  "productName": "Cove Windows Optimizer",
  "version": "0.1.0",
  "identifier": "com.cove.optimizer",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --prefix ../../ui dev",
    "beforeBuildCommand": "pnpm --prefix ../../ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Cove Windows Optimizer",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
